generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- 0. ENUMS ---
enum Rol {
  ADMIN
  EMPRENDEDORA
}

// --- 1. USUARIOS (Autenticación y Perfil) ---
model Usuario {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String   // Hash
  rol           Rol      @default(EMPRENDEDORA)
  activo        Boolean  @default(true)

  // Datos Personales (Perfil)
  nombre        String
  fechaNacimiento DateTime?
  ubicacion     String?
  ocupacion     String?
  fechaIngreso  DateTime @default(now())

  // Relaciones
  productos     Producto[]
  ventas        Venta[]
  clientes      Cliente[]
  configuracion Configuracion?
  catalogo      CatalogoPublico?

  // MAPEO: La tabla en la BD se llama 'usuario'
  @@map("usuario")
}

// --- 2. PRODUCTOS (Por Usuario) ---
model Producto {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  nombre        String
  sku           String
  categoria     String
  stock         Int      @default(0)

  // Costos variables
  insumoBase    Float
  tipoCaja      String   @default("ninguna")
  usaImpresion  Boolean  @default(false)
  imagen        String?
  descripcion   String?  @db.Text
  activo        Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  detalles      DetalleVenta[]

  @@unique([sku, usuarioId])
  
  // MAPEO: La tabla en la BD se llama 'producto'
  @@map("producto")
}

// --- 3. CONFIGURACIÓN (Por Usuario) ---
model Configuracion {
  id                  Int    @id @default(autoincrement())
  usuarioId           Int    @unique
  usuario             Usuario @relation(fields: [usuarioId], references: [id])

  precioBolsa         Float  @default(12.0)
  precioCajaChica     Float  @default(12.0)
  precioCajaGrande    Float  @default(45.0)
  precioImpresion     Float  @default(6.50)
  precioTiempo        Float  @default(7.00)

  margenPublico       Float @default(1.60)
  margenEmprendedora  Float @default(1.35)
  margenDistribuidora Float @default(1.45)

  nombreMarca         String @default("Le Bisou Joyería")
  colorMarca          String @default("#fbcdcf")
  mensajePiePagina    String @default("Precios sujetos a cambio sin previo aviso.")

  // MAPEO: La tabla en la BD se llama 'configuracion'
  @@map("configuracion")
}

// --- 4. CATÁLOGO PÚBLICO (Por Usuario) ---
model CatalogoPublico {
  id                   Int      @id @default(autoincrement())
  usuarioId            Int      @unique
  usuario              Usuario  @relation(fields: [usuarioId], references: [id])

  activo               Boolean  @default(true)
  tituloPestana        String   @default("Mi Catálogo")
  mensajeMantenimiento String   @default("Estamos preparando la nueva colección...")
  layout               Json?
  ultimaActualizacion  DateTime @default(now())

  // MAPEO: La tabla en la BD se llama 'catalogopublico'
  @@map("catalogopublico")
}

// --- 5. CLIENTES (Cartera de Clientes por Usuario) ---
model Cliente {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  nombre        String
  telefono      String?
  email         String?
  fechaRegistro DateTime @default(now())

  ventas        Venta[]

  @@unique([telefono, usuarioId])

  // MAPEO: La tabla en la BD se llama 'cliente'
  @@map("cliente")
}

// --- 6. VENTAS (Historial por Usuario) ---
model Venta {
  id            Int      @id @default(autoincrement())
  usuarioId     Int
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  total         Decimal
  fecha         DateTime @default(now())

  clienteId     Int?
  cliente       Cliente? @relation(fields: [clienteId], references: [id])

  detalles      DetalleVenta[]

  // MAPEO: La tabla en la BD se llama 'venta'
  @@map("venta")
}

// --- 7. DETALLE VENTA ---
model DetalleVenta {
  id             Int      @id @default(autoincrement())
  ventaId        Int
  venta          Venta    @relation(fields: [ventaId], references: [id])

  productoId     Int
  producto       Producto @relation(fields: [productoId], references: [id])

  cantidad       Int
  precioUnitario Decimal
  esRegalo       Boolean  @default(false)

  // MAPEO: La tabla en la BD se llama 'detalleventa'
  @@map("detalleventa")
}