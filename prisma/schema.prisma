generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --- 0. ENUMS ---
enum Rol {
  ADMIN
  EMPRENDEDORA
}

// --- 1. USUARIOS (Autenticación y Perfil) ---
model Usuario {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  password        String   // Hash
  rol             Rol      @default(EMPRENDEDORA)
  activo          Boolean  @default(true)

  // Datos Personales (Perfil)
  nombre          String
  fechaNacimiento DateTime?
  ubicacion       String?
  ocupacion       String?
  fechaIngreso    DateTime @default(now()) // Para calcular regalos de aniversario

  // Relaciones (Todo lo que le pertenece a este usuario)
  productos       Producto[]
  ventas          Venta[]
  clientes        Cliente[]
  configuracion   Configuracion? // Configuración propia (colores, margenes)
  catalogo        CatalogoPublico? // Su página pública
}

// --- 2. PRODUCTOS (Por Usuario) ---
model Producto {
  id             Int      @id @default(autoincrement())

  // Relación con Usuario (Dueño del producto)
  usuarioId      Int
  usuario        Usuario  @relation(fields: [usuarioId], references: [id])

  nombre         String
  sku            String
  categoria      String
  stock          Int      @default(0)

  // Costos variables
  insumoBase     Float
  tipoCaja       String   @default("ninguna")
  usaImpresion   Boolean  @default(false)
  imagen         String?
  descripcion    String?  @db.Text
  activo         Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  detalles       DetalleVenta[]

  // REGLA: El SKU debe ser único SOLO para ese usuario.
  // (La emprendedora A y B pueden tener ambas el SKU "001")
  @@unique([sku, usuarioId])
}

// --- 3. CONFIGURACIÓN (Por Usuario) ---
// Cada emprendedora podría tener sus propios márgenes o colores si así lo decides.
model Configuracion {
  id               Int    @id @default(autoincrement())

  usuarioId        Int    @unique // Una config por usuario
  usuario          Usuario @relation(fields: [usuarioId], references: [id])

  // Costos Fijos (Quizás el Admin define esto, pero lo dejo aquí por si varía)
  precioBolsa      Float  @default(12.0)
  precioCajaChica  Float  @default(12.0)
  precioCajaGrande Float  @default(45.0)
  precioImpresion  Float  @default(6.50)
  precioTiempo     Float  @default(7.00)

  // Márgenes de Ganancia
  margenPublico       Float @default(1.60)
  margenEmprendedora  Float @default(1.35)
  margenDistribuidora Float @default(1.45)

  // Identidad Visual
  nombreMarca      String @default("Le Bisou Joyería")
  colorMarca       String @default("#fbcdcf")
  mensajePiePagina String @default("Precios sujetos a cambio sin previo aviso.")
}

// --- 4. CATÁLOGO PÚBLICO (Por Usuario) ---
model CatalogoPublico {
  id                   Int      @id @default(autoincrement())

  usuarioId            Int      @unique // Un catálogo por usuario
  usuario              Usuario  @relation(fields: [usuarioId], references: [id])

  activo               Boolean  @default(true)
  tituloPestana        String   @default("Mi Catálogo")
  mensajeMantenimiento String   @default("Estamos preparando la nueva colección...")
  layout               Json?    // Aquí guardas el orden de SUS productos
  ultimaActualizacion  DateTime @default(now())
}

// --- 5. CLIENTES (Cartera de Clientes por Usuario) ---
model Cliente {
  id            Int      @id @default(autoincrement())

  usuarioId     Int
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  nombre        String
  telefono      String?
  email         String?
  fechaRegistro DateTime @default(now())

  ventas        Venta[]

  // REGLA: El teléfono es único solo dentro de la lista de la emprendedora
  @@unique([telefono, usuarioId])
}

// --- 6. VENTAS (Historial por Usuario) ---
model Venta {
  id            Int      @id @default(autoincrement())

  usuarioId     Int
  usuario       Usuario  @relation(fields: [usuarioId], references: [id])

  total         Decimal
  fecha         DateTime @default(now())

  clienteId     Int?
  cliente       Cliente? @relation(fields: [clienteId], references: [id])

  detalles      DetalleVenta[]
}

// --- 7. DETALLE VENTA (Queda igual, se conecta por relación) ---
model DetalleVenta {
  id             Int      @id @default(autoincrement())
  ventaId        Int
  venta          Venta    @relation(fields: [ventaId], references: [id])

  productoId     Int
  producto       Producto @relation(fields: [productoId], references: [id])

  cantidad       Int
  precioUnitario Decimal
  esRegalo       Boolean  @default(false)
}
